# Node / site build
node_modules/
dist/
.cache/
*.log

# Генерируется build_manifest.py. Версионируем, чтобы GitHub Pages мог его отдавать
# (сайт читает manifest.json по HTTP). Пересобирается дневным скриптом и коммитится.

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Secrets — НИКОГДА не коммитим токены/ключи
.env
.env.*
*.secret
secrets.json
.secrets.ps1
**/.secrets.ps1

# Рабочие временные файлы (вычисления sha1, выгрузки url и т.п.)
_tmp_*

# сырые дампы постобработки (engine/postprocess_finds.py)
radars/*/data/_raw/

# python bytecode
__pycache__/
*.pyc
